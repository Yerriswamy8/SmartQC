DJANGO_SECRET_KEY=replace-this-for-real-deployment
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
DEMO_ALLOW_ANONYMOUS=true
TIME_ZONE=Asia/Kolkata

# sqlite (default) or mysql
DB_ENGINE=sqlite
DB_NAME=smartqc_demo
DB_USER=smartqc
DB_PASSWORD=smartqc_demo
DB_HOST=127.0.0.1
DB_PORT=3306

# local (default) or s3
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=demo_storage
AWS_S3_BUCKET=
AWS_REGION=ap-south-1
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# opencv (default) or yolo
AI_BACKEND=opencv
YOLO_MODEL_PATH=
AI_CONFIDENCE_THRESHOLD=0.35
MAX_UPLOAD_SIZE_MB=25
